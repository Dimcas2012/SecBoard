# =============================================================================
# SecBoard Community Edition — environment configuration template
# EN: Open Core (AGPL v3). A community or enterprise license key is required.
# UK: Open Core (AGPL v3). Потрібен community або enterprise license key.
# EN: Copy to .env and fill in your values. Do NOT commit .env to git.
# UK: Скопіюйте у .env та заповніть своїми значеннями. НЕ комітьте .env у git.
# =============================================================================

# Django SECRET_KEY — unique per installation
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-new-secret-key

# Google reCAPTCHA v3 keys (leave empty to skip captcha checks)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Fernet key for webhook encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=

# Debug mode (1=on, 0=off). Must be 0 in production!
DEBUG=0

# Database connection
DB_ENGINE=django.db.backends.mysql
DB_NAME=secboard_base
DB_USER=secboard_user
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=3306

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost,your.site.domain

# CSRF trusted origins (comma-separated, full scheme+host+port)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://your.site.domain

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://your.site.domain

# CORS allowed origin regexes (comma-separated)
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.your\.site\.domain$

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Timezone
TIMEZONE=Europe/Kyiv

# Site URL / email settings
PUBLIC_BASE_URL=https://your.site.domain
DEFAULT_FROM_EMAIL=noreply@your.site.domain
SITE_DOMAIN=your.site.domain
SITE_PROTOCOL=https

# Optional: internal license server host (leave empty for public license.secboard.online only)
# LICENSE_SERVER_INTERNAL_HOST=
