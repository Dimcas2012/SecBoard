msgstr "Видалити коментарі перекладача"

#: app_ai/templates/app_ai/translate_po.html:378
#: app_conf/templates/app_conf/translate_po.html:588
msgid ""
"Clear translator comments from entries. This removes any notes left for "
"translators."
msgstr ""
"Видалити коментарі перекладача із записів. Це видаляє будь-які примітки, "
"залишені для перекладачів."

